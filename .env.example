# ============================================================================
# SRE Agent configuration — copy to .env and fill in.
# All values have sane defaults; nothing here is required for the local demo.
# ============================================================================

# --- LLM provider selection -------------------------------------------------
# Auto if unset. Order: openai → anthropic → ollama.
# SRE_LLM_PROVIDER=ollama        # ollama | openai | anthropic

# Per-role overrides. Default for everything is `auto`.
# SRE_LLM_ORCHESTRATOR=gpt-4o          # Incident PM, Hypothesis Gen, Remediation Sug
# SRE_LLM_WORKER=gpt-4o-mini           # Log Detective, Metrics Analyst, Trace Reader, Deploy Historian

# Ollama (local, free)
# OLLAMA_BASE_URL=http://localhost:11434
# SRE_LLM_ORCHESTRATOR=gpt-oss:20b
# SRE_LLM_WORKER=qwen2.5-coder:7b

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- Data source -----------------------------------------------------------
# `mock` (default) reads from mocks/scenarios.json — no external deps.
# `datadog` calls the Datadog API.
SRE_DATA_PROVIDER=mock

# DD_API_KEY=...
# DD_APP_KEY=...
# DD_SITE=datadoghq.com

# --- Persistence -----------------------------------------------------------
# `sqlite` is default (zero-config, file in ./.state/checkpoints.db).
# `postgres` is recommended for production — survives container restarts.
SRE_CHECKPOINTER=sqlite

# Postgres (used when SRE_CHECKPOINTER=postgres)
# DATABASE_URL=postgresql://sre:sre@localhost:5432/sre_agent

# --- Dashboard -------------------------------------------------------------
SRE_DASHBOARD_PORT=5080    # avoid 5060 — Chrome blocks it as unsafe (SIP)

# --- Slack (v1 — optional) -------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Logging --------------------------------------------------------------
SRE_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
SRE_LOG_JSON=false          # true for prod (structured logs)
