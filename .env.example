# ============================================================================
# SRE Agent configuration — copy to .env and fill in.
# All values have sane defaults; nothing here is required for the local demo.
# ============================================================================

# --- LLM provider selection -------------------------------------------------
# Auto if unset. Order: openai → anthropic → ollama.
# SRE_LLM_PROVIDER=ollama        # ollama | openai | anthropic

# Per-role overrides. Default for everything is `auto`.
# SRE_LLM_ORCHESTRATOR=gpt-4o          # Incident PM, Hypothesis Gen, Remediation Sug
# SRE_LLM_WORKER=gpt-4o-mini           # Log Detective, Metrics Analyst, Trace Reader, Deploy Historian

# Ollama (local, free)
# OLLAMA_BASE_URL=http://localhost:11434
# SRE_LLM_ORCHESTRATOR=gpt-oss:20b
# SRE_LLM_WORKER=qwen2.5-coder:7b

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- Data source -----------------------------------------------------------
# `mock`       reads from mocks/scenarios.json — no external deps (default)
# `datadog`    calls the Datadog API (DD_API_KEY + DD_APP_KEY)
# `oss`        Prometheus + Loki via CompositeProvider (demo-stack)
# `prometheus` metrics-only
# `loki`       logs-only
SRE_DATA_PROVIDER=mock

# Datadog
# DD_API_KEY=...
# DD_APP_KEY=...
# DD_SITE=datadoghq.com         # datadoghq.eu / us3.datadoghq.com / ap1.datadoghq.com
# DD_HTTP_TIMEOUT_S=10

# Open-source stack (demo-stack/docker-compose.yml)
# PROMETHEUS_URL=http://localhost:9090
# LOKI_URL=http://localhost:3100
# LOKI_QUERY='{{service="{service}"}} |~ "(?i)error|exception"'

# Per-metric PromQL overrides (use your own metric names)
# PROM_QUERY_REQ_RATE=...
# PROM_QUERY_ERROR_RATE=...
# PROM_QUERY_LATENCY_P99=...
# PROM_QUERY_CPU=...
# PROM_QUERY_MEM=...

# --- Persistence -----------------------------------------------------------
# `sqlite` is default (zero-config, file in ./.state/checkpoints.db).
# `postgres` is recommended for production — survives container restarts.
SRE_CHECKPOINTER=sqlite

# Postgres (used when SRE_CHECKPOINTER=postgres)
# DATABASE_URL=postgresql://sre:sre@localhost:5432/sre_agent

# --- Dashboard -------------------------------------------------------------
SRE_DASHBOARD_PORT=5080    # avoid 5060 — Chrome blocks it as unsafe (SIP)

# --- Slack notifications (optional) ---------------------------------------
# Unset → /api/incidents/<id>/post-slack returns a preview ("dry run") instead
# of POSTing. Set the URL to enable real posting.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SRE_SLACK_DRY_RUN=true        # force preview-only even when URL is set

# --- Inbound webhooks (optional) ------------------------------------------
# When set, /api/alerts/webhook requires `X-SRE-Token: <secret>`.
# Leave unset for local development / interview demos.
# SRE_WEBHOOK_SECRET=changeme

# --- Logging --------------------------------------------------------------
SRE_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
SRE_LOG_JSON=false          # true for prod (structured logs)
